{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Airis",
    "version": "2.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": true,
        "open": true,
        "sidecar": false,
        "scope": [
          { "name": "cmd", "cmd": "cmd", "args": true },
          { "name": "start", "cmd": "cmd", "args": true },
          { "name": "code", "cmd": "code", "args": true },
          { "name": "notepad", "cmd": "notepad", "args": true },
          { "name": "calc", "cmd": "calc", "args": true },
          { "name": "explorer", "cmd": "explorer", "args": true },
          { "name": "powershell", "cmd": "powershell", "args": true },
          { "name": "msedge", "cmd": "msedge", "args": true },
          { "name": "firefox", "cmd": "firefox", "args": true }
        ]
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["msi", "deb", "appimage"],
      "identifier": "com.airis.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "title": "Airis",
        "width": 1280,
        "height": 860,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      }
    ]
  }
}
