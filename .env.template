# Jarvis AI — copy to .env (dev) or edit %LOCALAPPDATA%\JarvisAI\.env after install.
# AI providers: Groq + Ollama only.

GROQ_API_KEY=

# Optional: override default Groq chat model
# GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_URL=http://127.0.0.1:11434

# Fallback model name if Ollama /api/tags cannot be reached
OLLAMA_MODEL=llama3.2

# Firebase Authentication (email + password; Gmail addresses work as email)
FIREBASE_API_KEY=

# Voice: Fish Audio (recommended) — https://fish.audio/app/
FISH_AUDIO_API_KEY=
# Voice model id from Fish (or use Clone voice after setting API key)
FISH_AUDIO_REFERENCE_ID=
# TTS engine header: s2-pro (default) or s1
FISH_AUDIO_MODEL=s2-pro

# Optional: ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
